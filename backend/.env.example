# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Database
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=beauty_app_dev
DB_HOST=127.0.0.1
DB_PORT=5432

# Production (Render.com)
# DATABASE_URL=postgresql://user:password@host/dbname

# JWT
JWT_SECRET=change_this_secret_very_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_very_long
JWT_REFRESH_EXPIRES_IN=30d

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Brevo (SMTP)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your_brevo_login
BREVO_SMTP_PASS=your_brevo_smtp_key
BREVO_FROM_EMAIL=noreply@beaute-app.com
BREVO_FROM_NAME=Beauté App
